class Solution {
    public int search(int[] arr, int t) {
        int l=0;
        int r=arr.length-1;
        while(l<=r){
            int mid=(l+r)/2;
            if(arr[mid]==t)
               return mid;
            else if(arr[mid]>t)
               r=mid-1;
            else
               l=mid+1;
        }
        return -1;
    }
}
