class Solution {
    public int bs(int[] nums,int t){
        int l=0;
        int r=nums.length-1;
        while(l<=r){
            int m=l+(r-l)/2;
            if(nums[m]>=t){
                r=m-1;
            }else{
                l=m+1;
            }
        }
        return l;
    }
    public int maximumCount(int[] nums) {
    int neg=bs(nums,0);
    int one=bs(nums,1);
    int pos=nums.length-one;
    int ans=Math.max(neg,pos);
    return ans;
    }
}
